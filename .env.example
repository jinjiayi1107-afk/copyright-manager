# ============================================================
# 环境变量配置示例
# 说明：复制此文件为 .env 并修改为实际值
# 注意：.env 文件不要提交到Git仓库！
# ============================================================

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=copyright_user
DB_PASSWORD=your_mysql_password_here
DB_NAME=copyright_manager

# 接口安全令牌（必须设置，否则所有写接口无法使用）
ADMIN_TOKEN=your_secure_token_here

# 可选：Gunicorn配置覆盖
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=60
